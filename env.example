# Copy this file to:
#   ~/.config/codex-discord-notifier/env
#
# Then paste your Discord channel webhook URL below.
# Keep this file private. The webhook URL is a credential.

DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/REPLACE_ME"

# Notify only turns/jobs that ran at least this many seconds.
CODEX_NOTIFY_MIN_SECONDS=3

# Polling every 2 seconds is lightweight: read-only SQLite queries only.
CODEX_NOTIFY_POLL_SECONDS=2

# Optional display name in Discord notifications.
CODEX_NOTIFY_HOST="codex-host"

# Mention target placed in the plain Discord message content.
# Default behavior is @here, which is best used in a private channel.
# Set to an empty string to disable pings, or to <@USER_ID> / <@&ROLE_ID>.
CODEX_NOTIFY_MENTION="@here"
